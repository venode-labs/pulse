#!/bin/sh
# Anti-fingerprint backstop. Two checks:
#   1. Reject commits whose author identity is a known bot.
#   2. Reject staged content carrying AI attribution markers.
#
# Enable on a clone with:
#   git config core.hooksPath .githooks
#
# Catches Claude, Codex, ChatGPT and similar tools that default to
# their vendor noreply identity in sandboxed sessions. Real humans
# pass through.

email=$(git config user.email)
name=$(git config user.name)

case "$email" in
  *@anthropic.com|*@openai.com|*@noreply.openai.com|*claude*|*codex*|*chatgpt*)
    cat >&2 <<EOM
error: refusing commit with bot-style author email
  user.email = $email
  user.name  = $name

Set a human identity, for example:
  git config user.email "casper@venode.au"
  git config user.name  "Kaspar Tavitian"
Then retry.
EOM
    exit 1
    ;;
esac

case "$name" in
  Claude|Codex|ChatGPT|Cursor|"GitHub Copilot"|*"AI Assistant"*|*"AI Agent"*)
    cat >&2 <<EOM
error: refusing commit with bot-style author name
  user.name  = $name
  user.email = $email

Set a human identity, for example:
  git config user.name  "Kaspar Tavitian"
  git config user.email "casper@venode.au"
Then retry.
EOM
    exit 1
    ;;
esac

markers=$(
  git diff --cached --no-color -- . \
      ':(exclude)CLAUDE.md' \
      ':(exclude).githooks/pre-commit' \
      ':(exclude).github/workflows/*' \
    | grep -E '^\+[^+]' \
    | grep -iE \
        'co-authored-by:.*(claude|codex|chatgpt|copilot|cursor)|generated (with|by) claude|created by claude|generated by an? (ai|llm|assistant|language model)|as an? (ai|llm|language model|assistant)|🤖 generated' \
  || true
)

if [ -n "$markers" ]; then
  cat >&2 <<EOM
error: refusing commit, AI attribution marker in staged content
$markers

Remove the marker, then retry.
EOM
  exit 1
fi

exit 0
