#!/usr/bin/env bash
# pulse-collector. Probes the host, pulls four threat feeds, matches
# CVEs against installed packages, writes the JSON state. Five-minute
# systemd user timer. No root, no privileged ops.
#
# (c) Venode Labs. MIT.

set -u

STATE="${XDG_STATE_HOME:-$HOME/.local/state}/pulse"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/pulse"
CONFIG_FILE="$CONFIG_DIR/config.toml"
BASELINE_DIR="$CONFIG_DIR/baselines"
mkdir -p "$STATE" "$BASELINE_DIR"

LOG="$STATE/collector.log"
HEALTH="$STATE/health.json"
THREATS="$STATE/threats.json"
RELEVANT="$STATE/relevant.json"
INSTALLED="$STATE/installed.json"
SCORE="$STATE/score.json"
NOTIF_STATE="$STATE/notif-state.json"

log() { printf '[%s] %s\n' "$(date -Iseconds)" "$*" >> "$LOG"; }

trim_log() {
    if [[ -f "$LOG" ]] && (( $(wc -l < "$LOG") > 2000 )); then
        tail -1000 "$LOG" > "$LOG.tmp" && mv "$LOG.tmp" "$LOG"
    fi
}

atomic_write() {
    local path="$1"
    cat > "$path.new" && mv "$path.new" "$path"
}

need_jq() {
    if ! command -v jq >/dev/null 2>&1; then
        log 'jq not on PATH'
        return 1
    fi
}

###############################################################################
# Config
###############################################################################

# Plain key=value reader. Strips inline comments, trims whitespace,
# refuses anything that looks like a shell metacharacter. Sets
# CFG_<key> in the environment.
load_config() {
    # Defaults
    CFG_feed_kev=true
    CFG_feed_arch=true
    CFG_feed_nvd=true
    CFG_feed_ghsa=true
    CFG_feed_epss=true
    CFG_severity_threshold=high
    CFG_notify_enabled=true
    CFG_notify_cooldown_minutes=60
    CFG_score_history_days=30
    CFG_relevant_cap=50
    CFG_kev_max_age_days=365
    CFG_nvd_max_age_days=30
    CFG_llm_endpoint=
    CFG_llm_token=

    [[ -r "$CONFIG_FILE" ]] || return 0
    local line key val
    while IFS= read -r line; do
        line="${line%%#*}"
        line="${line%"${line##*[![:space:]]}"}"
        line="${line#"${line%%[![:space:]]*}"}"
        [[ -z "$line" ]] && continue
        key="${line%%=*}"
        val="${line#*=}"
        key="${key%"${key##*[![:space:]]}"}"
        val="${val#"${val%%[![:space:]]*}"}"
        val="${val%"${val##*[![:space:]]}"}"
        case "$key" in
            feed_kev|feed_arch|feed_nvd|feed_ghsa|feed_epss\
            |notify_enabled)
                [[ "$val" == "true" || "$val" == "false" ]] && \
                    eval "CFG_$key=\"\$val\""
                ;;
            severity_threshold)
                case "$val" in
                    low|medium|high|critical) CFG_severity_threshold="$val" ;;
                esac
                ;;
            notify_cooldown_minutes|score_history_days|relevant_cap\
            |kev_max_age_days|nvd_max_age_days)
                [[ "$val" =~ ^[0-9]+$ ]] && eval "CFG_$key=\"\$val\""
                ;;
            llm_endpoint)
                [[ "$val" =~ ^https?://[A-Za-z0-9./_\:-]+$ ]] && \
                    CFG_llm_endpoint="$val"
                ;;
            llm_token)
                [[ "$val" =~ ^[A-Za-z0-9._-]+$ ]] && CFG_llm_token="$val"
                ;;
        esac
    done < "$CONFIG_FILE"
}

# Severity numeric ranking, used for floor comparisons.
sev_rank() {
    case "$1" in
        critical) echo 4 ;;
        high)     echo 3 ;;
        medium)   echo 2 ;;
        low)      echo 1 ;;
        *)        echo 0 ;;
    esac
}

###############################################################################
# Health probes
#
# Every probe returns a JSON object with three required keys plus
# free-form facts:
#
#   severity:  one of ok | info | warn | critical (drives the score)
#   status:    a short literal observation ('nftables active', '3 unexpected
#              listeners', etc) — what the probe SAW
#   message:   a human-friendly sentence carrying the evidence that
#              earned the severity. Surfaced under each probe in the
#              widget Local tab so the score is never opaque.
#
# emit_probe is the only path that produces a probe payload, so the
# contract is enforced in one place.
###############################################################################

emit_probe() {
    local severity=$1 status=$2 message=$3 extra=${4:-'{}'}
    jq -n \
        --arg severity "$severity" \
        --arg status   "$status" \
        --arg message  "$message" \
        --argjson extra "$extra" \
        '{severity:$severity, status:$status, message:$message} + $extra'
}

probe_firewall() {
    local engine='none' active=0
    for unit in nftables.service iptables.service ip6tables.service firewalld.service ufw.service; do
        if systemctl is-active --quiet "$unit"; then
            engine="${unit%.service}"
            active=1
            break
        fi
    done
    if (( active == 1 )); then
        emit_probe 'ok' "$engine active" \
            "Firewall service $engine is running." \
            "$(jq -n --arg engine "$engine" '{engine:$engine, active:true}')"
    else
        emit_probe 'critical' 'no firewall active' \
            'No firewall service is running (checked nftables, iptables, ip6tables, firewalld, ufw).' \
            '{"engine":"none","active":false}'
    fi
}

probe_apparmor() {
    local active=0 installed=0
    command -v apparmor_status >/dev/null 2>&1 && installed=1
    systemctl is-active --quiet apparmor.service && active=1
    if (( active == 1 )); then
        emit_probe 'ok' 'apparmor active' 'AppArmor service is running.' '{"installed":true,"active":true}'
    elif (( installed == 1 )); then
        emit_probe 'warn' 'apparmor installed, not active' \
            'AppArmor tools are present but apparmor.service is not running.' \
            '{"installed":true,"active":false}'
    else
        emit_probe 'warn' 'apparmor not installed' \
            'AppArmor is not installed on this system.' \
            '{"installed":false,"active":false}'
    fi
}

probe_usbguard() {
    local active=0 installed=0
    command -v usbguard >/dev/null 2>&1 && installed=1
    systemctl is-active --quiet usbguard.service && active=1
    if (( active == 1 )); then
        emit_probe 'ok' 'usbguard active' 'usbguard service is running and enforcing USB policy.' '{"installed":true,"active":true}'
    elif (( installed == 1 )); then
        emit_probe 'warn' 'usbguard installed, not active' \
            'usbguard is installed but usbguard.service is not running; USB policy is not being enforced.' \
            '{"installed":true,"active":false}'
    else
        emit_probe 'info' 'usbguard not installed' \
            'usbguard is not installed; USB device policy is not enforced. Optional on workstations.' \
            '{"installed":false,"active":false}'
    fi
}

probe_updates() {
    local total=0 kernel_pending=0 sample=''
    if command -v checkupdates >/dev/null 2>&1; then
        local out
        out=$(checkupdates 2>/dev/null || true)
        total=$(printf '%s' "$out" | grep -c . || true)
        printf '%s' "$out" | grep -q '^linux ' && kernel_pending=1
        # First 5 names for the message
        sample=$(printf '%s' "$out" | awk '{print $1}' | head -5 | paste -sd, -)
    fi
    local sev='ok' status="$total updates pending" message=''
    if (( total == 0 )); then
        message='System is fully up to date against the Arch repositories.'
    else
        message="$total updates pending"
        [[ -n "$sample" ]] && message="$message ($sample$( (( total > 5 )) && echo ', …' )"
        message="$message)."
        (( total > 50 )) && sev='warn'
        if (( kernel_pending == 1 )); then
            sev='warn'
            message="$message Kernel update is in the pending set; reboot needed after upgrade."
        fi
    fi
    emit_probe "$sev" "$status" "$message" \
        "$(jq -n --argjson t "$total" --argjson k "$kernel_pending" --arg sample "$sample" \
            '{total:$t, kernel_pending:($k == 1), sample:$sample}')"
}

probe_secureboot() {
    local sb='unknown'
    if command -v bootctl >/dev/null 2>&1; then
        if bootctl status 2>/dev/null | grep -qE 'Secure Boot: enabled'; then
            sb='enabled'
        elif bootctl status 2>/dev/null | grep -qE 'Secure Boot: disabled'; then
            sb='disabled'
        fi
    fi
    case "$sb" in
        enabled)
            emit_probe 'ok' 'secure boot enabled' \
                'UEFI Secure Boot is enabled; bootloader and kernel signatures are verified at boot.' \
                '{"state":"enabled"}' ;;
        disabled)
            emit_probe 'warn' 'secure boot disabled' \
                'UEFI Secure Boot is supported by the firmware but currently disabled.' \
                '{"state":"disabled"}' ;;
        *)
            emit_probe 'info' 'secure boot state unknown' \
                'bootctl could not determine Secure Boot state (not booted via systemd-boot or no UEFI variables readable).' \
                '{"state":"unknown"}' ;;
    esac
}

probe_tpm() {
    local present=0 device=''
    [[ -c /dev/tpm0 ]] && { present=1; device='/dev/tpm0'; }
    [[ -c /dev/tpmrm0 ]] && device="${device:+$device, }/dev/tpmrm0"
    if (( present == 1 )); then
        emit_probe 'ok' 'TPM present' "TPM character device available at $device." \
            "$(jq -n --arg device "$device" '{present:true, device:$device}')"
    else
        emit_probe 'info' 'no TPM device' \
            'No /dev/tpm0 device node; TPM is either absent, disabled in firmware, or the tpm_tis module is not loaded.' \
            '{"present":false}'
    fi
}

probe_luks() {
    local has=0 devices=''
    if command -v lsblk >/dev/null 2>&1; then
        devices=$(lsblk -no NAME,FSTYPE 2>/dev/null | awk '$2 == "crypto_LUKS" {print $1}' | paste -sd, -)
        [[ -n "$devices" ]] && has=1
    fi
    if (( has == 1 )); then
        emit_probe 'ok' 'LUKS volume present' \
            "Encrypted LUKS volume(s) detected: $devices." \
            "$(jq -n --arg dev "$devices" '{present:true, devices:$dev}')"
    else
        emit_probe 'warn' 'no LUKS volume found' \
            'No crypto_LUKS volumes mounted. Disk encryption is not in use on any block device this host can see.' \
            '{"present":false}'
    fi
}

probe_failed_logins() {
    local count=0 sample=''
    count=$(journalctl --since='24 hours ago' --no-pager 2>/dev/null \
            | grep -cE 'authentication failure|Failed password|FAILED LOGIN' || true)
    if (( count > 0 )); then
        sample=$(journalctl --since='24 hours ago' --no-pager 2>/dev/null \
                 | grep -E 'authentication failure|Failed password|FAILED LOGIN' \
                 | tail -1 | sed -E 's/.*: //' | cut -c1-120)
    fi
    local sev='ok'
    (( count > 5 ))  && sev='warn'
    (( count > 20 )) && sev='critical'
    local message
    if (( count == 0 )); then
        message='No failed authentication events in the last 24 hours.'
    else
        message="$count failed auth event(s) in the last 24 hours."
        [[ -n "$sample" ]] && message="$message Last: $sample"
    fi
    emit_probe "$sev" "$count failed in 24h" "$message" \
        "$(jq -n --argjson c "$count" --arg s "$sample" '{count_24h:$c, last_sample:$s}')"
}

probe_listening_ports() {
    # Externally-bound listeners (0.0.0.0 or [::]). Each entry:
    # {proto, port, process, addr}. ss without root can only see processes
    # the user owns, so process is often '-'. We back-fill with a well-
    # known-port map so 'sshd:22' is named even when ss returns '-'.
    # De-duplicated by (proto, port, process) so the v4+v6 pair counts once.
    local items='[]' raw=''
    if command -v ss >/dev/null 2>&1; then
        raw=$(ss -H -tunlp 2>/dev/null | awk '
            $5 ~ /^(0\.0\.0\.0|\[::\]):/ {
                proto = $1
                addr  = $5
                n = split(addr, parts, ":")
                port = parts[n]
                proc = "-"
                for (i = 6; i <= NF; i++) {
                    if ($i ~ /^users:/) {
                        if (match($i, /"[^"]+"/)) {
                            proc = substr($i, RSTART+1, RLENGTH-2)
                        }
                        break
                    }
                }
                print proto"\t"port"\t"proc"\t"addr
            }')
    fi
    if [[ -n "$raw" ]]; then
        items=$(printf '%s\n' "$raw" \
            | LC_ALL=C sort -u \
            | jq -nR '
                # Well-known port -> probable service. Used when ss did
                # not report a process name (ss without root can not see
                # processes owned by other users like root or systemd-
                # resolve). The mapping is conservative and lists the
                # service that owns the port on a typical Arch + KDE box.
                def port_service:
                    {
                      "22":   "sshd",
                      "53":   "systemd-resolved",
                      "67":   "dhcp",
                      "68":   "dhcp",
                      "80":   "http",
                      "111":  "rpcbind",
                      "123":  "ntp",
                      "137":  "samba-nmbd",
                      "138":  "samba-nmbd",
                      "139":  "samba-smbd",
                      "143":  "imap",
                      "443":  "https",
                      "445":  "samba-smbd",
                      "465":  "smtps",
                      "514":  "syslog",
                      "546":  "dhcp6",
                      "547":  "dhcp6",
                      "631":  "cups",
                      "636":  "ldaps",
                      "873":  "rsync",
                      "993":  "imaps",
                      "995":  "pop3s",
                      "3306": "mysql",
                      "5353": "avahi-daemon",
                      "5355": "systemd-resolved",
                      "5432": "postgres",
                      "6379": "redis",
                      "8080": "http-alt",
                      "8443": "https-alt",
                      "11434":"ollama",
                      "27017":"mongo"
                    };
                [inputs | split("\t") | {
                    proto:    .[0],
                    port:     (.[1] | tonumber? // .[1]),
                    raw_proc: .[2],
                    addr:     .[3]
                }
                | . + { process:
                    (if .raw_proc != "-" and .raw_proc != "" then .raw_proc
                     else (port_service[(.port | tostring)] // "unknown")
                     end) }
                | del(.raw_proc)
                ]
                | group_by(.proto + ":" + (.port|tostring) + ":" + .process)
                | map(.[0])
            ' 2>/dev/null || echo '[]')
    fi

    # Default allowlist: services expected to listen externally on a
    # typical Arch + KDE workstation. Operator can override via the
    # listening_allowlist key in config.toml.
    local allow_json='["sshd","systemd-resolve","systemd-resolved","avahi-daemon","cups-browsed","cupsd","NetworkManager","dhcp","dhcp6","ntp"]'
    if [[ -n "${CFG_listening_allowlist:-}" ]]; then
        allow_json=$(printf '%s' "$CFG_listening_allowlist" \
            | jq -R 'split(",") | map(. | sub("^\\s+"; "") | sub("\\s+$"; ""))' \
            2>/dev/null || printf '%s' "$allow_json")
    fi

    local total=0 unexpected=0
    total=$(printf '%s' "$items" | jq 'length')
    local unexpected_items
    unexpected_items=$(printf '%s' "$items" | jq --argjson allow "$allow_json" \
        '[.[] | select(.process as $p | $allow | index($p) == null)]')
    unexpected=$(printf '%s' "$unexpected_items" | jq 'length')

    local sev='ok' status='' message=''
    if (( total == 0 )); then
        status='no externally-bound listeners'
        message='Nothing is listening on a public interface.'
    elif (( unexpected == 0 )); then
        local listing
        listing=$(printf '%s' "$items" | jq -r '[.[] | "\(.process):\(.port)/\(.proto)"] | join(", ")')
        sev='info'
        status="$total expected listener(s)"
        message="Only well-known services exposed: $listing."
    else
        local unexpected_listing
        unexpected_listing=$(printf '%s' "$unexpected_items" | jq -r '[.[] | "\(.process):\(.port)/\(.proto)"] | join(", ")')
        sev='warn'
        (( unexpected > 3 )) && sev='critical'
        status="$total listener(s), $unexpected unexpected"
        message="Unexpected externally-bound services: $unexpected_listing. Allowlist them in config.toml if intentional."
    fi

    emit_probe "$sev" "$status" "$message" \
        "$(jq -n --argjson items "$items" \
                 --argjson total "$total" \
                 --argjson unexpected "$unexpected" \
                 --argjson unexpected_items "$unexpected_items" \
                 --argjson allow "$allow_json" \
            '{external_listeners:$total, unexpected:$unexpected, items:$items, unexpected_items:$unexpected_items, allow:$allow}')"
}

probe_vpn() {
    local iface=''
    if command -v ip >/dev/null 2>&1; then
        iface=$(ip -o link show 2>/dev/null \
            | awk -F': ' '{print $2}' \
            | grep -E '^(proton[0-9]+|wg[0-9]+|tun[0-9]+|tailscale[0-9]+)$' | head -1)
    fi
    if [[ -n "$iface" ]]; then
        emit_probe 'ok' "$iface up" "VPN interface $iface is up." \
            "$(jq -n --arg if "$iface" '{active:true, interface:$if}')"
    else
        emit_probe 'info' 'no VPN interface' \
            'No VPN interface detected (looked for proton*, wg*, tun*, tailscale*).' \
            '{"active":false,"interface":null}'
    fi
}

# Kernel staleness: days since the running kernel was packaged. Reads
# the install date from pacman, not the upstream release date.
probe_kernel_age() {
    local days=-1 running pkg='linux' ver='' install_date=''
    running=$(uname -r)
    if pacman -Q linux-zen >/dev/null 2>&1 && [[ $running == *-zen ]]; then pkg='linux-zen'; fi
    if pacman -Q linux-lts >/dev/null 2>&1 && [[ $running == *-lts ]]; then pkg='linux-lts'; fi
    if pacman -Q linux-hardened >/dev/null 2>&1 && [[ $running == *-hardened ]]; then pkg='linux-hardened'; fi
    ver=$(pacman -Q "$pkg" 2>/dev/null | awk '{print $2}')
    if [[ -n "$ver" ]]; then
        install_date=$(pacman -Qi "$pkg" 2>/dev/null \
            | awk -F': ' '/^Install Date/ {print $2}' | sed 's/^[ \t]*//')
        if [[ -n "$install_date" ]]; then
            local secs
            secs=$(date -d "$install_date" +%s 2>/dev/null || echo 0)
            if (( secs > 0 )); then
                days=$(( ( $(date +%s) - secs ) / 86400 ))
            fi
        fi
    fi
    local sev='ok'
    (( days > 60 ))  && sev='warn'
    (( days > 120 )) && sev='critical'
    local status="kernel $running, ${days} day(s) since install"
    local message
    if (( days < 0 )); then
        message='Could not determine kernel install date (pacman query failed).'
        sev='info'
    elif (( days <= 14 )); then
        message="Running kernel $running from package $pkg $ver, installed $days day(s) ago."
    else
        message="Running kernel $running ($pkg $ver) is $days day(s) old. Reboot to apply newer kernel if pacman -Syu has pulled one."
    fi
    emit_probe "$sev" "$status" "$message" \
        "$(jq -n --arg r "$running" --arg p "$pkg" --arg v "$ver" --argjson d "$days" \
            '{running:$r, package:$p, installed_version:$v, days_since_install:$d}')"
}

# SUID / SGID inventory, with delta against a baseline if one exists.
probe_suid() {
    local current count=0 added=0 removed=0 baseline added_sample=''
    baseline="$BASELINE_DIR/suid.txt"
    current=$(find /usr/bin /usr/sbin /usr/local/bin /usr/local/sbin /opt -xdev \
              \( -perm -4000 -o -perm -2000 \) -type f 2>/dev/null \
              | LC_ALL=C sort -u)
    count=$(printf '%s\n' "$current" | grep -c . || true)
    if [[ -s "$baseline" ]]; then
        added=$(comm -23 <(printf '%s\n' "$current") "$baseline" 2>/dev/null | grep -c . || true)
        removed=$(comm -13 <(printf '%s\n' "$current") "$baseline" 2>/dev/null | grep -c . || true)
        added_sample=$(comm -23 <(printf '%s\n' "$current") "$baseline" 2>/dev/null | head -3 | paste -sd, -)
    fi
    local sev='ok'
    (( added > 0 ))  && sev='warn'
    (( added > 3 ))  && sev='critical'
    local present=false
    [[ -s "$baseline" ]] && present=true
    local status="$count suid/sgid binaries"
    local message
    if [[ "$present" == "false" ]]; then
        message="No baseline yet ($count suid/sgid binaries currently). Set one with: cp $baseline.new $baseline after reviewing."
        sev='info'
        # Save the current list as a candidate baseline for the operator to promote.
        printf '%s\n' "$current" > "$baseline.new"
    elif (( added == 0 && removed == 0 )); then
        message="$count suid/sgid binaries, matches baseline exactly."
    else
        message="$count suid/sgid binaries; $added added vs baseline"
        [[ -n "$added_sample" ]] && message="$message ($added_sample)"
        (( removed > 0 )) && message="$message, $removed removed"
        message="$message."
    fi
    emit_probe "$sev" "$status" "$message" \
        "$(jq -n --argjson c "$count" --argjson a "$added" --argjson r "$removed" \
                 --arg present "$present" --arg sample "$added_sample" \
            '{count:$c, added_since_baseline:$a, removed_since_baseline:$r,
              baseline_present:($present == "true"), added_sample:$sample}')"
}

# SSH hardening: effective settings for PasswordAuthentication and
# PermitRootLogin. Strategy (highest fidelity first):
#   1. `sshd -T -f <config>` prints the effective config including
#      defaults. Needs hostkey access so usually fails as a non-root
#      user; we try it anyway in case the operator has dropped to a
#      keyless test config.
#   2. Grep the literal config file. Includes drop-ins under
#      sshd_config.d/* in include order.
#   3. Fall back to documented OpenSSH defaults when neither path set
#      an explicit value. PasswordAuthentication defaults to yes, and
#      PermitRootLogin has defaulted to prohibit-password since 7.0.
#      We mark the source so the operator can see we are inferring.
probe_ssh() {
    local cfg=/etc/ssh/sshd_config password='' root='' installed=0
    local sshd_active=0 source='none'
    [[ -r "$cfg" ]] && installed=1
    systemctl is-active --quiet sshd.service && sshd_active=1

    if command -v sshd >/dev/null 2>&1; then
        local eff
        eff=$(sshd -T -f "$cfg" 2>/dev/null || true)
        if [[ -n "$eff" ]]; then
            source='sshd -T'
            password=$(printf '%s\n' "$eff" | awk 'tolower($1) == "passwordauthentication" {print $2; exit}')
            root=$(printf '%s\n'     "$eff" | awk 'tolower($1) == "permitrootlogin"        {print $2; exit}')
        fi
    fi

    # Grep the literal config (and drop-ins) when sshd -T did not give
    # us a value.
    if [[ -z "$password" || -z "$root" ]] && [[ -r "$cfg" ]]; then
        local configs=("$cfg")
        if [[ -d /etc/ssh/sshd_config.d ]]; then
            while IFS= read -r f; do configs+=("$f"); done < <(find /etc/ssh/sshd_config.d -maxdepth 1 -type f -name '*.conf' | LC_ALL=C sort)
        fi
        for f in "${configs[@]}"; do
            if [[ -z "$password" ]]; then
                local pv
                pv=$(awk '/^[[:space:]]*PasswordAuthentication[[:space:]]+/ {print $2}' "$f" 2>/dev/null | tail -1)
                [[ -n "$pv" ]] && password="$pv"
            fi
            if [[ -z "$root" ]]; then
                local rv
                rv=$(awk '/^[[:space:]]*PermitRootLogin[[:space:]]+/ {print $2}' "$f" 2>/dev/null | tail -1)
                [[ -n "$rv" ]] && root="$rv"
            fi
        done
        [[ "$source" == 'none' ]] && source='sshd_config'
    fi

    # Document defaults when no source set the field explicitly. Source
    # for these: OpenSSH manpage (sshd_config(5)).
    if [[ -z "$password" ]]; then password='yes'; source="$source+defaults"; fi
    if [[ -z "$root"     ]]; then root='prohibit-password'; source="${source%+defaults}+defaults"; fi

    local sev message status
    if (( installed == 0 )); then
        sev='info'
        status='sshd not present'
        message='OpenSSH server config not found; sshd is not installed on this host.'
    elif (( sshd_active == 0 )); then
        sev='ok'
        status="sshd present, not running (source: $source)"
        message="sshd_config present at $cfg, sshd.service is not active. Effective config (via $source): PasswordAuthentication=$password, PermitRootLogin=$root."
    else
        # sshd is running, so the effective settings matter to the score.
        sev='ok'
        status="sshd active, password=$password, root=$root"
        message="sshd is running (source: $source). PasswordAuthentication=$password, PermitRootLogin=$root."
        if [[ "$password" == 'yes' ]]; then
            sev='warn'
            message="$message PasswordAuthentication=yes weakens brute-force resistance; switch to key-based auth."
        fi
        case "$root" in
            yes)
                sev='critical'
                message="$message Root login is permitted directly; set PermitRootLogin no." ;;
            prohibit-password|without-password|forced-commands-only)
                : ;;  # acceptable (key-only or restricted)
        esac
    fi
    emit_probe "$sev" "$status" "$message" \
        "$(jq -n --argjson p "$installed" --argjson active "$sshd_active" \
                 --arg pw "$password" --arg root "$root" --arg src "$source" \
            '{sshd_config_present:($p == 1), sshd_active:($active == 1),
              password_auth:$pw, permit_root_login:$root, source:$src}')"
}

# Days since the last full system upgrade. Reads pacman log for the
# most recent "starting full system upgrade" event.
probe_last_upgrade() {
    local days=-1 last=''
    if [[ -r /var/log/pacman.log ]]; then
        last=$(grep -aE 'starting full system upgrade' /var/log/pacman.log 2>/dev/null \
               | tail -1 | sed -E 's/^\[([^]]+)\].*/\1/')
        if [[ -n "$last" ]]; then
            local secs
            secs=$(date -d "$last" +%s 2>/dev/null || echo 0)
            if (( secs > 0 )); then
                days=$(( ( $(date +%s) - secs ) / 86400 ))
            fi
        fi
    fi
    local sev='ok'
    (( days > 14 )) && sev='warn'
    (( days > 30 )) && sev='critical'
    local status='' message=''
    if (( days < 0 )); then
        sev='warn'
        status='no upgrade record found'
        message='Could not find any "starting full system upgrade" entry in /var/log/pacman.log.'
    else
        status="last pacman -Syu: $days day(s) ago"
        message="Last full system upgrade ran $days day(s) ago (at $last)."
    fi
    emit_probe "$sev" "$status" "$message" \
        "$(jq -n --argjson d "$days" --arg at "$last" '{days:$d, at:$at}')"
}

# Aggregate to a worst severity.
aggregate() {
    local worst='ok' s
    for s in "$@"; do
        case "$s" in
            critical) worst='critical' ;;
            warn)     [[ $worst != 'critical' ]] && worst='warn' ;;
            info)     [[ $worst == 'ok' ]] && worst='info' ;;
        esac
    done
    printf '%s' "$worst"
}

###############################################################################
# Threat feeds
###############################################################################

# CISA KEV.
fetch_kev() {
    [[ "$CFG_feed_kev" != true ]] && return 0
    local out="$STATE/kev.json"
    if curl -fsSL --max-time 20 \
        'https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json' \
        -o "$out.new" 2>>"$LOG"; then
        mv "$out.new" "$out"
        log "kev fetch ok"
        return 0
    fi
    log "kev fetch FAILED, keeping previous"
    return 1
}

# Arch Linux Security Advisories.
fetch_arch() {
    [[ "$CFG_feed_arch" != true ]] && return 0
    local out="$STATE/arch.json"
    if curl -fsSL --max-time 20 \
        'https://security.archlinux.org/issues/all.json' \
        -o "$out.new" 2>>"$LOG"; then
        mv "$out.new" "$out"
        log "arch fetch ok"
        return 0
    fi
    log "arch fetch FAILED, keeping previous"
    return 1
}

# NVD recent CVEs: published in the last 7 days. JSON v2 API, no key
# needed for low-volume reads. We page through the first 2000 results
# at most, sized for a personal-machine workload.
fetch_nvd() {
    [[ "$CFG_feed_nvd" != true ]] && return 0
    local out="$STATE/nvd.json"
    local now seven_ago
    now=$(date -u +%Y-%m-%dT%H:%M:%S.000)
    seven_ago=$(date -u -d '7 days ago' +%Y-%m-%dT%H:%M:%S.000)
    local url="https://services.nvd.nist.gov/rest/json/cves/2.0?pubStartDate=${seven_ago}&pubEndDate=${now}&resultsPerPage=2000"
    if curl -fsSL --max-time 45 -A 'pulse/0.2' "$url" -o "$out.new" 2>>"$LOG"; then
        mv "$out.new" "$out"
        log "nvd fetch ok"
        return 0
    fi
    log "nvd fetch FAILED, keeping previous"
    return 1
}

# GitHub Security Advisories. Public endpoint, no auth for low-volume.
fetch_ghsa() {
    [[ "$CFG_feed_ghsa" != true ]] && return 0
    local out="$STATE/ghsa.json"
    if curl -fsSL --max-time 30 \
        -H 'Accept: application/vnd.github+json' \
        -H 'X-GitHub-Api-Version: 2022-11-28' \
        'https://api.github.com/advisories?type=reviewed&per_page=100' \
        -o "$out.new" 2>>"$LOG"; then
        mv "$out.new" "$out"
        log "ghsa fetch ok"
        return 0
    fi
    log "ghsa fetch FAILED, keeping previous"
    return 1
}

# EPSS scores. Pulls scores for every CVE currently in the KEV catalogue;
# this keeps the dataset bounded and immediately useful for the
# exploited-in-the-wild bucket. Falls back to the latest top-100 if KEV
# isn't yet available.
fetch_epss() {
    [[ "$CFG_feed_epss" != true ]] && return 0
    local out="$STATE/epss.json"
    local cves=
    if [[ -s "$STATE/kev.json" ]]; then
        cves=$(jq -r '[.vulnerabilities[].cveID] | join(",")' "$STATE/kev.json" 2>/dev/null | head -c 7000)
    fi
    local url
    if [[ -n "$cves" ]]; then
        url="https://api.first.org/data/v1/epss?cve=${cves}&limit=1000"
    else
        url="https://api.first.org/data/v1/epss?order=!epss&limit=200"
    fi
    if curl -fsSL --max-time 30 -A 'pulse/0.2' "$url" -o "$out.new" 2>>"$LOG"; then
        mv "$out.new" "$out"
        log "epss fetch ok"
        return 0
    fi
    log "epss fetch FAILED, keeping previous"
    return 1
}

###############################################################################
# Installed-package inventory + relevance cross-reference
###############################################################################

snapshot_installed() {
    if ! command -v pacman >/dev/null 2>&1; then
        echo '[]' > "$INSTALLED"
        return
    fi
    pacman -Q 2>/dev/null \
      | awk '{print "{\"name\":\""$1"\",\"version\":\""$2"\"}"}' \
      | jq -s '.' > "$INSTALLED.new" 2>>"$LOG" && mv "$INSTALLED.new" "$INSTALLED"
}

# Build a flat list of relevant CVEs across the four feeds. A CVE is
# relevant if its package name matches one in the local pacman inventory.
# Severity floor honoured. Output is capped.
compute_relevant() {
    local cap="$CFG_relevant_cap"
    local floor_rank
    floor_rank=$(sev_rank "$CFG_severity_threshold")

    local installed_names
    installed_names=$(jq -r '.[].name' "$INSTALLED" 2>/dev/null | LC_ALL=C sort -u)

    # Set of CVE ids that Arch upstream has already patched. Cross-
    # referenced against every feed below so a CVE Arch has shipped a
    # fix for never re-surfaces as critical. The user's box is one
    # pacman -Syu away from current at any point.
    local fixed_cves='[]'
    if [[ -s "$STATE/arch.json" ]]; then
        fixed_cves=$(jq '[.[] | select(.status == "Fixed" or .status == "Not affected") | (.issues // [])[]] | unique' "$STATE/arch.json" 2>>"$LOG" || echo '[]')
    fi

    if [[ -z "$installed_names" ]]; then
        echo '{"updated":"'"$(date -Iseconds)"'","items":[]}' > "$RELEVANT.new"
        mv "$RELEVANT.new" "$RELEVANT"
        return
    fi

    # Arch ALSA items map cleanly onto pacman package names. Status
    # filter is the most important line in this function: ALSA marks
    # an advisory "Fixed" once Arch ships a patched package version,
    # and on a current system the installed version is past that fix.
    # Including Fixed/Not-affected entries was the source of the
    # composite-score false positives.
    local arch_items='[]'
    if [[ -s "$STATE/arch.json" ]]; then
        arch_items=$(jq --argjson floor "$floor_rank" \
            --slurpfile inst <(jq '[.[].name]' "$INSTALLED") \
            '
            def sev_rank(s):
                if s == "Critical" then 4
                elif s == "High"     then 3
                elif s == "Medium"   then 2
                elif s == "Low"      then 1
                else 0 end;
            [.[] | select(.packages != null)
                | select(.status != "Fixed" and .status != "Not affected")
                | . as $a
                | .packages[]
                | . as $pkg
                | select(($inst[0] | index($pkg)) != null)
                | select(sev_rank($a.severity) >= $floor)
                | {
                    source: "arch",
                    id: $a.name,
                    package: $pkg,
                    severity: ($a.severity // "Unknown"),
                    status: ($a.status // "Unknown"),
                    advisories: ($a.advisories // []),
                    cves: ($a.issues // []),
                    title: ($a.type // $a.name),
                    url: ("https://security.archlinux.org/" + $a.name)
                  }
            ]
            ' "$STATE/arch.json" 2>>"$LOG" || echo '[]')
    fi

    # KEV: known-exploited. Match on vendor or product equal to (or
    # whose tokenised form contains) the installed package name. We
    # require package names >= 4 chars and word-boundary equality to
    # avoid spurious matches like "go" in "Google". Older-than-cutoff
    # entries are out of the relevance bucket (still queryable via
    # `pulse cves --kev`).
    local kev_cutoff
    kev_cutoff=$(date -u -d "$CFG_kev_max_age_days days ago" +%Y-%m-%d)
    local kev_items='[]'
    if [[ -s "$STATE/kev.json" ]]; then
        kev_items=$(jq \
            --arg cutoff "$kev_cutoff" \
            --argjson fixed "$fixed_cves" \
            --slurpfile inst <(jq '[.[].name | select(length >= 4)]' "$INSTALLED") \
            '
            def tokens(s):
                (s // "") | ascii_downcase
                | gsub("[^a-z0-9]+"; " ")
                | split(" ") | map(select(length > 0)) | unique;
            [.vulnerabilities[]
                | select((.dateAdded // "1970-01-01") >= $cutoff)
                | select(($fixed | index(.cveID)) == null)
                | . as $v
                | (tokens($v.product) + tokens($v.vendorProject)) as $toks
                | (($inst[0]) | map(select((. | ascii_downcase) as $p | ($toks | index($p)) != null))) as $hits
                | select(($hits | length) > 0)
                | {
                    source: "kev",
                    id: $v.cveID,
                    package: $hits[0],
                    severity: "Critical",
                    status: "KnownExploited",
                    advisories: [$v.cveID],
                    cves: [$v.cveID],
                    title: $v.vulnerabilityName,
                    vendor: $v.vendorProject,
                    product: $v.product,
                    added: $v.dateAdded,
                    ransomware: $v.knownRansomwareCampaignUse,
                    url: ("https://nvd.nist.gov/vuln/detail/" + $v.cveID)
                  }
            ]
            ' "$STATE/kev.json" 2>>"$LOG" || echo '[]')
    fi

    # NVD recent: match against the structured CPE product strings in
    # the cve.configurations tree, not free-text description. Same
    # word-boundary rule. Published-before-cutoff entries dropped.
    local nvd_cutoff
    nvd_cutoff=$(date -u -d "$CFG_nvd_max_age_days days ago" +%Y-%m-%dT%H:%M:%S)
    local nvd_items='[]'
    if [[ -s "$STATE/nvd.json" ]]; then
        nvd_items=$(jq --argjson floor "$floor_rank" \
            --arg cutoff "$nvd_cutoff" \
            --argjson fixed "$fixed_cves" \
            --slurpfile inst <(jq '[.[].name | select(length >= 4)]' "$INSTALLED") \
            '
            def sev_rank(s):
                if (s // "") | ascii_downcase | startswith("crit") then 4
                elif (s // "") | ascii_downcase | startswith("high") then 3
                elif (s // "") | ascii_downcase | startswith("med") then 2
                elif (s // "") | ascii_downcase | startswith("low") then 1
                else 0 end;
            [.vulnerabilities[]? | .cve as $c
                | select(($c.published // "1970") >= $cutoff)
                | select(($fixed | index($c.id)) == null)
                | (($c.metrics.cvssMetricV31 // [])[0].cvssData.baseSeverity // "") as $sev
                | select(sev_rank($sev) >= $floor)
                | (
                    [($c.configurations // [])[]? | .nodes[]? | .cpeMatch[]? | .criteria // empty]
                    | map(split(":")) | map(select(length >= 5)) | map(.[4])
                    | map(ascii_downcase) | unique
                  ) as $cpe_products
                | (($inst[0]) | map(select((. | ascii_downcase) as $p | ($cpe_products | index($p)) != null))) as $hits
                | select(($hits | length) > 0)
                | {
                    source: "nvd",
                    id: $c.id,
                    package: $hits[0],
                    severity: $sev,
                    status: "Disclosed",
                    advisories: [$c.id],
                    cves: [$c.id],
                    title: (($c.descriptions // [])[0].value // $c.id),
                    url: ("https://nvd.nist.gov/vuln/detail/" + $c.id),
                    published: $c.published
                  }
            ]
            ' "$STATE/nvd.json" 2>>"$LOG" || echo '[]')
    fi

    # Merge, de-dup by id+package, sort by severity then recency, cap.
    local items
    items=$(jq -s --argjson cap "$cap" \
        '
        def sev_score(s):
            if (s | ascii_downcase) | startswith("crit") then 4
            elif (s | ascii_downcase) | startswith("high") then 3
            elif (s | ascii_downcase) | startswith("med") then 2
            elif (s | ascii_downcase) | startswith("low") then 1
            else 0 end;
        (.[0] + .[1] + .[2])
        | group_by(.id + "|" + .package)
        | map(.[0])
        | sort_by(- sev_score(.severity), -((.added // .published // "") | tostring | length))
        | .[0:$cap]
        ' <(printf '%s' "$arch_items") <(printf '%s' "$kev_items") <(printf '%s' "$nvd_items") 2>>"$LOG" || echo '[]')

    # Splice EPSS probabilities onto matching CVE rows.
    if [[ -s "$STATE/epss.json" ]]; then
        items=$(jq -s \
            '
            (.[1].data // []) as $epss
            | (reduce $epss[] as $e ({}; . + {($e.cve): {epss: ($e.epss | tonumber), percentile: ($e.percentile | tonumber)}})) as $by_cve
            | (.[0] | map(. + (($by_cve[(.cves // [.id])[0]]) // {})))
            ' <(printf '%s' "$items") "$STATE/epss.json" 2>>"$LOG" || printf '%s' "$items")
    fi

    jq -n --argjson items "$items" --arg ts "$(date -Iseconds)" \
        --arg floor "$CFG_severity_threshold" \
        '{updated:$ts, severity_floor:$floor, count:($items | length), items:$items}' \
        > "$RELEVANT.new" && mv "$RELEVANT.new" "$RELEVANT"
}

###############################################################################
# Composite risk score + history
###############################################################################

# 0 (worst) to 100 (best). Combines local health, count of relevant
# unresolved CVEs weighted by severity, kernel age, days since upgrade,
# and listening-port surface.
compose_score() {
    local health_score=0
    [[ -s "$HEALTH" ]] && health_score=$(jq -r '.score // 0' "$HEALTH")

    local n_crit n_high n_med
    n_crit=0; n_high=0; n_med=0
    if [[ -s "$RELEVANT" ]]; then
        n_crit=$(jq -r '[.items[] | select((.severity // "" | ascii_downcase) | startswith("crit"))] | length' "$RELEVANT")
        n_high=$(jq -r '[.items[] | select((.severity // "" | ascii_downcase) | startswith("high"))] | length' "$RELEVANT")
        n_med=$(jq -r  '[.items[] | select((.severity // "" | ascii_downcase) | startswith("med"))]  | length' "$RELEVANT")
    fi
    local cve_penalty=$(( n_crit * 8 + n_high * 4 + n_med * 1 ))
    (( cve_penalty > 60 )) && cve_penalty=60

    local final=$(( health_score - cve_penalty ))
    (( final < 0 ))   && final=0
    (( final > 100 )) && final=100

    # Append to rolling history.
    local now_iso ts hist days_cap
    now_iso=$(date -Iseconds)
    ts=$(date +%s)
    days_cap="$CFG_score_history_days"
    local cutoff=$(( ts - days_cap * 86400 ))
    hist='[]'
    [[ -s "$SCORE" ]] && hist=$(jq -c '.history // []' "$SCORE")

    jq -n \
        --arg now "$now_iso" \
        --argjson score "$final" \
        --argjson health "$health_score" \
        --argjson crit "$n_crit" \
        --argjson high "$n_high" \
        --argjson med "$n_med" \
        --argjson hist "$hist" \
        --argjson cutoff "$cutoff" \
        '
        ($hist + [{at:$now, score:$score, ts:(now | floor)}])
        | map(select(.ts >= $cutoff))
        | sort_by(.ts)
        | { updated:$now,
            score:$score,
            health_score:$health,
            relevant: {critical:$crit, high:$high, medium:$med},
            history: . }
        ' > "$SCORE.new" && mv "$SCORE.new" "$SCORE"
}

###############################################################################
# Notifications
###############################################################################

# Fires a desktop notification when a new critical-or-higher relevant
# CVE appears that wasn't there on the previous run. Respects the
# cooldown.
maybe_notify() {
    [[ "$CFG_notify_enabled" != true ]] && return 0
    [[ -s "$RELEVANT" ]] || return 0
    command -v notify-send >/dev/null 2>&1 || return 0

    local floor_rank
    floor_rank=$(sev_rank "$CFG_severity_threshold")

    local current_ids
    current_ids=$(jq -r --argjson floor "$floor_rank" '
        def sev_rank(s):
            if (s // "" | ascii_downcase) | startswith("crit") then 4
            elif (s // "" | ascii_downcase) | startswith("high") then 3
            elif (s // "" | ascii_downcase) | startswith("med")  then 2
            elif (s // "" | ascii_downcase) | startswith("low")  then 1
            else 0 end;
        [.items[] | select(sev_rank(.severity) >= $floor) | (.id + "|" + .package)] | sort | unique | .[]
    ' "$RELEVANT" 2>/dev/null)

    local prev_ids='' last_at=0
    if [[ -s "$NOTIF_STATE" ]]; then
        prev_ids=$(jq -r '.seen[]?' "$NOTIF_STATE" 2>/dev/null)
        last_at=$(jq -r '.last_fired // 0' "$NOTIF_STATE" 2>/dev/null)
    fi

    local newly
    newly=$(comm -23 <(printf '%s\n' "$current_ids" | sort -u) <(printf '%s\n' "$prev_ids" | sort -u) 2>/dev/null | grep -c . || true)

    local now_ts cooldown_secs
    now_ts=$(date +%s)
    cooldown_secs=$(( CFG_notify_cooldown_minutes * 60 ))

    if (( newly > 0 )) && (( now_ts - last_at > cooldown_secs )); then
        local summary
        summary=$(jq -r --argjson floor "$floor_rank" '
            def sev_rank(s):
                if (s // "" | ascii_downcase) | startswith("crit") then 4
                elif (s // "" | ascii_downcase) | startswith("high") then 3
                else 0 end;
            [.items[] | select(sev_rank(.severity) >= $floor)] | .[0:3] |
            map((.severity[0:1] | ascii_upcase) + " " + .id + " on " + .package) | join(" \n ")
        ' "$RELEVANT" 2>/dev/null)
        notify-send -a 'Security Pulse' -i security-high -u critical \
            "$newly new vulnerability alert(s)" "$summary" 2>>"$LOG" || true
        last_at="$now_ts"
    fi

    jq -n --argjson last "$last_at" --arg list "$current_ids" \
        '{last_fired:$last, seen:($list | split("\n") | map(select(length>0)))}' \
        > "$NOTIF_STATE.new" && mv "$NOTIF_STATE.new" "$NOTIF_STATE"
}

###############################################################################
# Hugo briefing (optional)
###############################################################################

maybe_brief() {
    [[ -n "$CFG_llm_endpoint" && -n "$CFG_llm_token" ]] || return 0
    [[ -s "$RELEVANT" ]] || return 0

    local payload
    payload=$(jq -c '{
        ask: "Three sentences. Plain English. Worst-first. What should the user fix on this machine today, given this Security Pulse snapshot? No marketing language.",
        snapshot: {
            score: (input | .score),
            health: (input | .items),
            top_relevant: (input | .items[0:5])
        }
    }' "$SCORE" <(jq '{score:.score, items:.items[0:0]}' "$SCORE") "$RELEVANT" 2>>"$LOG" || echo '{}')

    curl -fsSL --max-time 25 -X POST \
        -H "Authorization: Bearer $CFG_llm_token" \
        -H 'Content-Type: application/json' \
        -d "$payload" \
        "$CFG_llm_endpoint" -o "$STATE/briefing.json.new" 2>>"$LOG" \
        && mv "$STATE/briefing.json.new" "$STATE/briefing.json"
}

###############################################################################
# Compose JSON
###############################################################################

write_health() {
    local fw aa ug up sb tpm luks fl lp vpn kern suid ssh upg
    fw=$(probe_firewall)
    aa=$(probe_apparmor)
    ug=$(probe_usbguard)
    up=$(probe_updates)
    sb=$(probe_secureboot)
    tpm=$(probe_tpm)
    luks=$(probe_luks)
    fl=$(probe_failed_logins)
    lp=$(probe_listening_ports)
    vpn=$(probe_vpn)
    kern=$(probe_kernel_age)
    suid=$(probe_suid)
    ssh=$(probe_ssh)
    upg=$(probe_last_upgrade)

    local sevs=()
    for j in "$fw" "$aa" "$ug" "$up" "$sb" "$tpm" "$luks" "$fl" "$lp" "$vpn" "$kern" "$suid" "$ssh" "$upg"; do
        sevs+=("$(printf '%s' "$j" | jq -r .severity)")
    done
    local overall
    overall=$(aggregate "${sevs[@]}")

    # Each ok=10, info=8, warn=5, critical=0; normalised to 100.
    local raw=0 count=${#sevs[@]} s
    for s in "${sevs[@]}"; do
        case "$s" in
            ok)       raw=$((raw+10)) ;;
            info)     raw=$((raw+8)) ;;
            warn)     raw=$((raw+5)) ;;
            critical) ;;
        esac
    done
    local score=$(( raw * 100 / (count * 10) ))

    jq -n \
        --argjson firewall "$fw" \
        --argjson apparmor "$aa" \
        --argjson usbguard "$ug" \
        --argjson updates "$up" \
        --argjson secureboot "$sb" \
        --argjson tpm "$tpm" \
        --argjson luks "$luks" \
        --argjson failedlogins "$fl" \
        --argjson listeners "$lp" \
        --argjson vpn "$vpn" \
        --argjson kernel "$kern" \
        --argjson suid "$suid" \
        --argjson ssh "$ssh" \
        --argjson upgrade "$upg" \
        --arg overall "$overall" \
        --argjson score "$score" \
        --arg ts "$(date -Iseconds)" \
        --arg host "$(hostname)" \
        '{updated:$ts, overall:$overall, score:$score, host:$host,
          items:{
            firewall:$firewall, apparmor:$apparmor, usbguard:$usbguard,
            updates:$updates, secureboot:$secureboot, tpm:$tpm, luks:$luks,
            failed_logins:$failedlogins, listening_ports:$listeners,
            vpn:$vpn, kernel:$kernel, suid:$suid, ssh:$ssh,
            last_upgrade:$upgrade
          }}' \
        > "$HEALTH.new" && mv "$HEALTH.new" "$HEALTH"
}

write_threats() {
    local kev_file="$STATE/kev.json"
    local arch_file="$STATE/arch.json"
    local nvd_file="$STATE/nvd.json"
    local ghsa_file="$STATE/ghsa.json"
    local kev_summary='null' arch_summary='null' nvd_summary='null' ghsa_summary='null'

    if [[ -s $kev_file ]]; then
        kev_summary=$(jq '{
            total: (.vulnerabilities | length),
            new_week: ([.vulnerabilities[] | select(.dateAdded >= (now - 86400*7 | strftime("%Y-%m-%d")))] | length),
            recent: ([.vulnerabilities[] | {cve: .cveID, vendor: .vendorProject, product: .product, name: .vulnerabilityName, added: .dateAdded, ransomware: .knownRansomwareCampaignUse}] | sort_by(.added) | reverse | .[0:8])
        }' "$kev_file" 2>>"$LOG" || echo 'null')
    fi

    if [[ -s $arch_file ]]; then
        arch_summary=$(jq '{
            total: length,
            new_week: ([.[] | select(.status == "Vulnerable" or .status == "Unknown")] | length),
            recent: ([.[] | {id: .name, packages: .packages, severity: .severity, status: .status}] | sort_by(.id) | reverse | .[0:8])
        }' "$arch_file" 2>>"$LOG" || echo 'null')
    fi

    if [[ -s $nvd_file ]]; then
        nvd_summary=$(jq '{
            total: (.totalResults // (.vulnerabilities | length)),
            recent: ([.vulnerabilities[]? | .cve | {
                id: .id,
                published: .published,
                severity: ((.metrics.cvssMetricV31 // [])[0].cvssData.baseSeverity // "Unknown"),
                title: ((.descriptions // [])[0].value // .id)
            }] | sort_by(.published) | reverse | .[0:8])
        }' "$nvd_file" 2>>"$LOG" || echo 'null')
    fi

    if [[ -s $ghsa_file ]]; then
        ghsa_summary=$(jq '{
            total: length,
            recent: ([.[] | {
                id: .ghsa_id,
                cve: .cve_id,
                severity: .severity,
                summary: .summary,
                published: .published_at,
                url: .html_url
            }] | sort_by(.published) | reverse | .[0:8])
        }' "$ghsa_file" 2>>"$LOG" || echo 'null')
    fi

    jq -n \
        --argjson kev "$kev_summary" \
        --argjson arch "$arch_summary" \
        --argjson nvd "$nvd_summary" \
        --argjson ghsa "$ghsa_summary" \
        --arg ts "$(date -Iseconds)" \
        '{updated:$ts, kev:$kev, arch:$arch, nvd:$nvd, ghsa:$ghsa}' \
        > "$THREATS.new" && mv "$THREATS.new" "$THREATS"
}

###############################################################################
# Main
###############################################################################

main() {
    need_jq || exit 1
    load_config
    log "collector run start (severity floor: $CFG_severity_threshold)"

    snapshot_installed

    fetch_kev  || true
    fetch_arch || true
    fetch_nvd  || true
    fetch_ghsa || true
    fetch_epss || true

    write_health
    write_threats
    compute_relevant
    compose_score
    maybe_notify
    maybe_brief

    log "run done: overall=$(jq -r .overall "$HEALTH") health=$(jq -r .score "$HEALTH")/100 composite=$(jq -r .score "$SCORE")/100 relevant=$(jq -r .count "$RELEVANT")"
    trim_log
}

main "$@"
