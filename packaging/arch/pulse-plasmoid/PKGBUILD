# Maintainer: Venode Labs <labs@venode.ai>

pkgname=pulse-plasmoid
pkgver=0.3.0
pkgrel=1
pkgdesc='KDE Plasma 6 widget for pulse, the host security pulse-check'
arch=('any')
url='https://github.com/keletonik/pulse'
license=('MIT')
depends=('plasma-workspace' 'pulse')
source=("pulse-$pkgver.tar.gz::https://github.com/keletonik/pulse/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

package() {
    cd "$srcdir/pulse-$pkgver"

    local plasma_dir="usr/share/plasma/plasmoids/com.casper.pulse"
    install -d "$pkgdir/$plasma_dir"
    cp -r plasmoid/com.casper.pulse/. "$pkgdir/$plasma_dir/"

    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
